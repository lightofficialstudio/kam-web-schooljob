// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Enum Definitions ---

enum UserRole {
  TEACHER // สำหรับคุณครู (หางาน)
  SCHOOL // สำหรับโรงเรียน (ประกาศงานและหาคน)
  ADMIN // สำหรับแอดมิน (จัดการระบบหลังบ้าน)
}

enum JobStatus {
  OPEN
  CLOSED
  DRAFT
}

// --- Models ---

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id") // Link to Supabase Auth ID
  email     String   @unique
  fullName  String?  @map("full_name")
  role      UserRole @default(TEACHER)
  avatarUrl String?  @map("avatar_url")

  // Teacher specific
  headline   String?
  bio        String?
  experience Int? // Years of experience
  skills     String[] // AntD Select tags

  // School specific
  schoolName String? @map("school_name")
  location   String?
  website    String?

  jobs      Job[]    @relation("PostedBy")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("profiles")
}

model Job {
  id          String    @id @default(uuid())
  title       String
  description String
  location    String
  salary      String?
  type        String // e.g., Full-time, Part-time
  subjects    String[] // Relevant subjects
  status      JobStatus @default(OPEN)

  authorId String  @map("author_id")
  author   Profile @relation("PostedBy", fields: [authorId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("jobs")
}

model Application {
  id          String @id @default(uuid())
  jobId       String @map("job_id")
  applicantId String @map("applicant_id")
  status      String @default("PENDING") // PENDING, REVIEWS, REJECTED, ACCEPTED

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("applications")
}
