siness/KAM-WEB-SCHOOLJOB/app/pages/employee/profile/_components/resume-upload-section.tsx", "source_location": "L130"}, {"caller_nid": "components_resume_upload_section_handlebeforeupload", "callee": "some", "is_member_call": true, "source_file": "/Users/light/Desktop/PORTFOLIO/Kam-Business/KAM-WEB-SCHOOLJOB/app/pages/employee/profile/_components/resume-upload-section.tsx", "source_location": "L140"}, {"caller_nid": "components_resume_upload_section_handlebeforeupload", "callee": "setModal", "is_member_call": false, "source_file": "/Users/light/Desktop/PORTFOLIO/Kam-Business/KAM-WEB-SCHOOLJOB/app/pages/employee/profile/_components/resume-upload-section.tsx", "source_location": "L141"}, {"caller_nid": "components_resume_upload_section_handlebeforeupload", "callee": "(async () => {\n      setIsUploading(true);\n      try {\n        const result = await uploadFile(\"resumes\", userId, file);\n        // \u2728 \u0e1a\u0e31\u0e19\u0e17\u0e36\u0e01\u0e25\u0e07 DB \u0e1c\u0e48\u0e32\u0e19 1:1 API \u0e41\u0e25\u0e49\u0e27\u0e43\u0e0a\u0e49 id \u0e08\u0e23\u0e34\u0e07\u0e08\u0e32\u0e01 response\n        const res = await postResume(userId, {\n          file_name: file.name,\n          file_url: result.url,\n          file_size: file.size,\n        });\n        const newResume: ResumeEntry = {\n          id: res.data?.id ?? `resume-${Date.now()}`,\n          fileName: file.name,\n          fileSize: file.size,\n          uploadedAt: new Date().toLocaleDateString(\"th-TH\"),\n          url: result.url,\n        };\n        addResume(newResume);\n        setModal({\n          open: true,\n          type: \"success\",\n          title: \"\u0e41\u0e19\u0e1a\u0e40\u0e23\u0e0b\u0e39\u0e40\u0e21\u0e48\u0e2a\u0e33\u0e40\u0e23\u0e47\u0e08\",\n          description: `\u0e44\u0e1f\u0e25\u0e4c \"${file.name}\" \u0e16\u0e39\u0e01\u0e2d\u0e31\u0e1b\u0e42\u0e2b\u0e25\u0e14\u0e41\u0e25\u0e30\u0e1a\u0e31\u0e19\u0e17\u0e36\u0e01\u0e40\u0e23\u0e35\u0e22\u0e1a\u0e23\u0e49\u0e2d\u0e22\u0e41\u0e25\u0e49\u0e27`,\n        });\n      } catch (err: unknown) {\n        const axiosErr = err as { response?: { data?: { message_th?: string } }; message?: string };\n        const description =\n          axiosErr?.response?.data?.message_th ||\n          axiosErr?.message ||\n          \"\u0e40\u0e01\u0e34\u0e14\u0e02\u0e49\u0e2d\u0e1c\u0e34\u0e14\u0e1e\u0e25\u0e32\u0e14\u0e02\u0e13\u0e30\u0e2d\u0e31\u0e1b\u0e42\u0e2b\u0e25\u0e14\u0e44\u0e1f\u0e25\u0e4c \u0e01\u0e23\u0e38\u0e13\u0e32\u0e25\u0e2d\u0e07\u0e43\u0e2b\u0e21\u0e48\u0e2d\u0e35\u0e01\u0e04\u0e23\u0e31\u0e49\u0e07\";\n        setModal({ open: true, type: \"error\", title: \"\u0e2d\u0e31\u0e1b\u0e42\u0e2b\u0e25\u0e14\u0e40\u0e23\u0e0b\u0e39\u0e40\u0e21\u0e48\u0e44\u0e21\u0e48\u0e2a\u0e33\u0e40\u0e23\u0e47\u0e08\", description, errorDetails: err });\n      } finally {\n        setIsUploading(false);\n      }\n    })", "is_member_call": false, "source_file": "/Users/light/Desktop/PORTFOLIO/Kam-Business/KAM-WEB-SCHOOLJOB/app/pages/employee/profile/_components/resume-upload-section.tsx", "source_location": "L151"}, {"caller_nid": "components_resume_upload_section_async", "callee": "setActiveResume", "is_member_call": false, "source_file": "/Users/light/Desktop/PORTFOLIO/Kam-Business/KAM-WEB-SCHOOLJOB/app/pages/employee/profile/_components/resume-upload-section.tsx", "source_location": "L255"}, {"caller_nid": "components_resume_upload_section_async", "callee": "test", "is_member_call": true, "source_file": "/Users/light/Desktop/PORTFOLIO/Kam-Business/KAM-WEB-SCHOOLJOB/app/pages/employee/profile/_components/resume-upload-section.tsx", "source_location": "L256"}, {"caller_nid": "components_resume_upload_section_async", "callee": "putResume", "is_member_call": false, "source_file": "/Users/light/Desktop/PORTFOLIO/Kam-Business/KAM-WEB-SCHOOLJOB/app/pages/employee/profile/_components/resume-upload-section.tsx", "source_location": "L259"}, {"caller_nid": "components_resume_upload_section_async", "callee": "setActiveResum